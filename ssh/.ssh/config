# Must be before any Host blocks
Include ~/.orbstack/ssh/config

Host *github*
  UseKeychain yes
  ForwardAgent yes
  AddKeysToAgent yes
  IdentityFile ~/.ssh/id_github_wadefletch

Host proxmox
  SetEnv TERM=xterm-256color

Host arrakis
  ForwardAgent yes
  IdentityFile ~/.ssh/id_github_wadefletch

Host corrino
  ForwardAgent yes
  IdentityFile ~/.ssh/id_github_wadefletch

