cmd - return : open -na "Alacritty" 

# focus window
ctrl - left : yabai -m window --focus west
ctrl - down : yabai -m window --focus south
ctrl - up : yabai -m window --focus north
ctrl - right : yabai -m window --focus east
 
# swap window
shift + ctrl - left : yabai -m window --swap west
shift + ctrl - down : yabai -m window --swap south
shift + ctrl - up : yabai -m window --swap north
shift + ctrl - right : yabai -m window --swap east
 
# move window
shift + cmd - left : yabai -m window --warp west
shift + cmd - down : yabai -m window --warp south
shift + cmd - up : yabai -m window --warp north
shift + cmd - right : yabai -m window --warp east
 
# balance size of windows
shift + alt - 0 : yabai -m space --balance

# rotate tree
ctrl - r : yabai -m space --rotate 90

# float / unfloat window
shift + ctrl - space : yabai -m window --toggle float

# float and center window
shift + ctrl - c : yabai -m window --toggle float;\
                   yabai -m window --grid 4:4:1:1:2:2

# make fullscreen
ctrl - f : yabai -m window --toggle zoom-fullscreen
shift + ctrl - f : yabai -m window --toggle native-fullscreen

# move focused window to workspace
shift + ctrl - 1 : yabai -m window --space 1 && yabai -m space --focus 1
shift + ctrl - 2 : yabai -m window --space 2 && yabai -m space --focus 2
shift + ctrl - 3 : yabai -m window --space 3 && yabai -m space --focus 3
shift + ctrl - 4 : yabai -m window --space 4 && yabai -m space --focus 4
shift + ctrl - 5 : yabai -m window --space 5 && yabai -m space --focus 5

# change space
ctrl - 1 : yabai -m space --focus 1
ctrl - 2 : yabai -m space --focus 2
ctrl - 3 : yabai -m space --focus 3
ctrl - 4 : yabai -m space --focus 4
ctrl - 5 : yabai -m space --focus 5
