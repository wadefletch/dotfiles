" Enable syntax highlighting
" Not sure the meaningful difference between 'enable' and 'on'
syntax enable

" ===== Make Tabs Spaces Again ======
" Use spaces instead of tabs
set expandtab

" Be smart when using tabs ;)
set smarttab

" 1 tab == 4 spaces
set shiftwidth=4
set tabstop=4


set ai "Auto indent
set si "Smart indent
set wrap "Wrap lines

" (Excerpt from https://github.com/amix/vimrc/blob/master/vimrcs/basic.vim)


" ====== Line Numbers =====
set number
highlight LineNr ctermfg=darkgrey


